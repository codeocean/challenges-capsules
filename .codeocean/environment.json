{
	"version": 1,
	"base_image": "codeocean/mambaforge3:22.11.1-4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"pip": {
			"packages": [
				{
					"name": "boto3",
					"version": "1.42.78"
				},
				{
					"name": "pandas",
					"version": "2.3.3"
				},
				{
					"name": "pronto",
					"version": "2.7.3"
				},
				{
					"name": "rapidfuzz",
					"version": "3.14.3"
				},
				{
					"name": "requests",
					"version": "2.33.1"
				},
				{
					"name": "strands-agents",
					"version": "1.33.0"
				},
				{
					"name": "strands-agents-tools",
					"version": "0.3.0"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
	},
	"env_variables": [
		{
			"name": "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
			"value": "100000"
		},
		{
			"name": "MAX_THINKING_TOKENS",
			"value": "10000"
		}
	]
}