{
	"version": 1,
	"base_image": "codeocean/mambaforge3:22.11.1-4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"pip": {
			"packages": [
				{
					"name": "matplotlib",
					"version": "3.10.8"
				},
				{
					"name": "numpy",
					"version": "2.2.6"
				},
				{
					"name": "pandas",
					"version": "2.3.3"
				},
				{
					"name": "scikit-image",
					"version": "0.25.2"
				},
				{
					"name": "scikit-learn",
					"version": "1.7.2"
				},
				{
					"name": "scipy",
					"version": "1.15.3"
				},
				{
					"name": "tifffile",
					"version": "2025.5.10"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
	},
	"env_variables": [
		{
			"name": "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
			"value": "100000"
		},
		{
			"name": "MAX_THINKING_TOKENS",
			"value": "10000"
		}
	]
}