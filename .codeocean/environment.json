{
	"version": 1,
	"base_image": "codeocean/mambaforge3:22.11.1-4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"env_variables": [
		{
			"name": "CLAUDE_CODE_USE_BEDROCK",
			"value": "1"
		},
		{
			"name": "AWS_REGION",
			"value": "us-east-1"
		}
	]
}