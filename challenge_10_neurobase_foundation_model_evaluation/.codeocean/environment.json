{
	"version": 1,
	"base_image": "codeocean/pytorch:2.4.0-cuda12.4.0-mambaforge24.5.0-0-python3.12.4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"pip": {
			"packages": [
				{
					"name": "matplotlib",
					"version": "3.10.8"
				},
				{
					"name": "numpy",
					"version": "2.4.4"
				},
				{
					"name": "pandas",
					"version": "3.0.1"
				},
				{
					"name": "pynrrd",
					"version": "1.1.3"
				},
				{
					"name": "requests",
					"version": "2.33.1"
				},
				{
					"name": "scikit-learn",
					"version": "1.8.0"
				},
				{
					"name": "torch",
					"version": "2.11.0"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
	},
	"env_variables": [
		{
			"name": "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
			"value": "100000"
		},
		{
			"name": "MAX_THINKING_TOKENS",
			"value": "10000"
		}
	]
}