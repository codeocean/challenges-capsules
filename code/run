#!/usr/bin/env bash
set -euo pipefail

# Canonical entrypoint path is exactly /code/run (file name "run", no extension).
# Do not rename this script to /code/run.py.

# Use a shared global npm bin path accessible to non-root users.
export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

# Optional: pin explicitly for reproducibility, for example:
#   CLAUDE_CODE_VERSION='@anthropic-ai/claude-code@1.0.0'
CLAUDE_CODE_VERSION="${CLAUDE_CODE_VERSION:-@anthropic-ai/claude-code}"
NPM_GLOBAL_PREFIX="${NPM_GLOBAL_PREFIX:-/usr/local}"

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

# Primary contract is to preconfigure apt packages via capsule_environment.
# This fallback attempts to self-heal missing runtime prerequisites.
ensure_runtime_apt_prereqs() {
  local -a missing=()
  for required_bin in runuser script curl gpg; do
    if ! has_cmd "${required_bin}"; then
      missing+=("${required_bin}")
    fi
  done

  if [[ ${#missing[@]} -eq 0 ]]; then
    return 0
  fi

  echo "Missing runtime prerequisites: ${missing[*]}. Attempting apt bootstrap..." >&2

  if ! has_cmd apt-get; then
    echo "apt-get not available. Configure apt_packages via capsule_environment before run." >&2
    exit 2
  fi

  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y --no-install-recommends \
    apt-transport-https ca-certificates curl gnupg util-linux bsdextrautils

  local -a still_missing=()
  for required_bin in runuser script curl gpg; do
    if ! has_cmd "${required_bin}"; then
      still_missing+=("${required_bin}")
    fi
  done

  if [[ ${#still_missing[@]} -gt 0 ]]; then
    echo "Missing required binaries after apt bootstrap: ${still_missing[*]}" >&2
    echo "Set apt_packages=[\"apt-transport-https\",\"ca-certificates\",\"curl\",\"gnupg\"] in capsule environment." >&2
    exit 2
  fi
}

ensure_runtime_apt_prereqs

# Install Node.js and Claude Code at runtime if not already present.
if ! command -v claude >/dev/null 2>&1; then
  echo "Claude Code not found. Installing Node.js and Claude Code at runtime..." >&2

  # Install Node.js 20.x from NodeSource if node is missing or too old.
  if ! command -v node >/dev/null 2>&1; then
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    apt-get install -y nodejs
  fi

  if ! command -v npm >/dev/null 2>&1; then
    echo "npm not found after Node.js install. Ensure nodejs package includes npm." >&2
    exit 2
  fi

  npm install -g --prefix "${NPM_GLOBAL_PREFIX}" "${CLAUDE_CODE_VERSION}"

  if ! command -v claude >/dev/null 2>&1; then
    echo "claude command not found after install. Check npm prefix and PATH." >&2
    exit 2
  fi

  echo "Claude Code installed successfully." >&2
fi

# ── appuser setup ────────────────────────────────────────────────────
if ! id appuser &>/dev/null; then
  useradd -m -u 1000 -s /bin/bash appuser
fi

HOME_DIR="$(eval echo ~appuser)"
mkdir -p "${HOME_DIR}"
chown -R appuser:appuser "${HOME_DIR}"

mkdir -p /code /scratch /results
chown -R appuser:appuser /code /scratch /results || true

if ! runuser -u appuser -- sh -lc 'claude --version >/dev/null 2>&1'; then
  echo "claude is not executable by appuser. Verify install prefix is /usr/local and PATH is correct." >&2
  exit 2
fi

cd /code

PROMPT="${*:-}"
if [[ -z "${PROMPT}" ]]; then
  echo "Usage: /code/run \"<prompt>\"" >&2
  exit 1
fi

# ── CRITICAL: backup /code to /results ──────────────────────────────
backup_code_to_results() {
  echo ">>> Backing up /code to /results/backup/code ..." >&2
  mkdir -p /results/backup
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete /code/ /results/backup/code/
  else
    rm -rf /results/backup/code
    cp -a /code /results/backup/code
  fi
  echo ">>> Backup complete: /results/backup/code" >&2
}
trap backup_code_to_results EXIT

# Diagnostic mode for non-interactive debugging.
if [[ "${DIAGNOSE:-0}" == "1" ]]; then
  echo "=== Claude Code Diagnose ==="
  id
  echo "PATH=${PATH}"
  command -v claude || true
  claude --version || true
  runuser -u appuser -- sh -lc 'id && command -v claude && claude --version' || true
  exit 0
fi

# Runtime defaults for Bedrock-backed Claude Code execution.
export CLAUDE_CODE_USE_BEDROCK="${CLAUDE_CODE_USE_BEDROCK:-1}"
export AWS_REGION="${AWS_REGION:-us-east-1}"
export DISABLE_PROMPT_CACHING="${DISABLE_PROMPT_CACHING:-1}"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${CLAUDE_CODE_MAX_OUTPUT_TOKENS:-8192}"
export MAX_THINKING_TOKENS="${MAX_THINKING_TOKENS:-2048}"
export CLAUDE_AGENTS_JSON="${CLAUDE_AGENTS_JSON:-}"
export CLAUDE_ACTIVE_AGENT="${CLAUDE_ACTIVE_AGENT:-}"

OUTPUT_FORMAT="${OUTPUT_FORMAT:-text}"

CLAUDE_AGENT_FLAGS=""
if [[ -n "${CLAUDE_AGENTS_JSON}" ]]; then
  CLAUDE_AGENT_FLAGS+=" --agents $(printf %q "${CLAUDE_AGENTS_JSON}")"
fi
if [[ -n "${CLAUDE_ACTIVE_AGENT}" ]]; then
  CLAUDE_AGENT_FLAGS+=" --agent $(printf %q "${CLAUDE_ACTIVE_AGENT}")"
fi

run_log="$(mktemp)"
run_claude_once() {
  runuser -u appuser -- \
    script -q -e -c \
      "claude -p $(printf %q "${PROMPT}") --verbose --output-format ${OUTPUT_FORMAT} --dangerously-skip-permissions${CLAUDE_AGENT_FLAGS}" \
      /dev/null
}

probe_current_model_support() {
  runuser -u appuser -- \
    script -q -e -c \
      "claude -p 'Model availability probe. Reply with: OK' --verbose --output-format text --dangerously-skip-permissions${CLAUDE_AGENT_FLAGS}" \
      /dev/null
}

is_model_failure() {
  local log_path="$1"
  grep -Eiq \
    "(model.*(not found|not supported|invalid|unavailable|access denied|does not have access)|validationexception|unsupported model|unknown model|cannot find model|inference profile)" \
    "${log_path}"
}

set +e
run_claude_once 2>&1 | tee "${run_log}"
first_status=$?
set -e

if [[ ${first_status} -ne 0 ]] && is_model_failure "${run_log}" && [[ "${ANTHROPIC_MODEL}" != "${ANTHROPIC_DEFAULT_OPUS_MODEL}" ]]; then
  echo "Model failure detected with '${ANTHROPIC_MODEL}'. Testing Opus fallback '${ANTHROPIC_DEFAULT_OPUS_MODEL}'..." >&2
  export ANTHROPIC_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL}"
  set +e
  probe_current_model_support >/dev/null 2>&1
  fallback_probe_status=$?
  set -e
  if [[ ${fallback_probe_status} -ne 0 ]]; then
    echo "Fallback model probe failed for '${ANTHROPIC_MODEL}'. Aborting." >&2
    exit "${fallback_probe_status}"
  fi
  echo "Fallback model probe succeeded. Retrying prompt with '${ANTHROPIC_MODEL}'..." >&2
  run_claude_once
else
  exit "${first_status}"
fi
